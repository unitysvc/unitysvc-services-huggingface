import os
import requests
from pathlib import Path

UNITYSVC_API_KEY = os.getenv("UNITYSVC_API_KEY")
SERVICE_BASE_URL = os.environ.get("SERVICE_BASE_URL")

def text_to_speech(
    model_id: str,
    text: str,
    output_path: str = "output.wav"
):
    url = f"{SERVICE_BASE_URL}/models/{{offering.name}}"

    headers = {
        "Authorization": f"Bearer {UNITYSVC_API_KEY}"
    }

    payload = {
        "inputs": text
    }

    response = requests.post(url, headers=headers, json=payload)

    if response.status_code == 503:
        raise RuntimeError("Model is loading. Retry in a few seconds.")

    response.raise_for_status()

    Path(output_path).write_bytes(response.content)
    return output_path


# ===== Example usage =====
if __name__ == "__main__":
    path = text_to_speech(
        model_id="{{offering.name}}",
        text="Hello. This is a reusable text to speech function."
    )
    print(f"Audio saved to {path}")
