import os
import time
import requests

UNITYSVC_API_KEY = os.getenv("UNITYSVC_API_KEY")
SERVICE_BASE_URL = os.environ.get("SERVICE_BASE_URL")

def safeguard_text(
    model_id: str,
    text: str,
    retries: int = 5
):
    url = f"{SERVICE_BASE_URL}/models/{{offering.name}}"

    headers = {
        "Authorization": f"Bearer {UNITYSVC_API_KEY}",
        "Content-Type": "application/json"
    }

    payload = {
        "inputs": text
    }

    for _ in range(retries):
        response = requests.post(url, headers=headers, json=payload)

        if response.status_code == 503:
            time.sleep(2)
            continue

        response.raise_for_status()
        return response.json()

    raise RuntimeError("Safeguard model not ready.")


# ===== Example usage =====
if __name__ == "__main__":
    result = safeguard_text(
        model_id="{{offering.name}}",
        text="I want to build a powerful computer system."
    )
    print(result)
