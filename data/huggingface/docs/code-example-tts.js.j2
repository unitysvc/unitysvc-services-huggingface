const UNITYSVC_API_KEY = process.env.UNITYSVC_API_KEY;

const response = await fetch(
  `https://router.huggingface.co/models/{{offering.name}}`,
  {
    method: "POST",
    headers: {
      "Authorization": `Bearer ${UNITYSVC_API_KEY}`,
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      inputs: "Hello from JavaScript. This is Hugging Face TTS."
    })
  }
);

if (!response.ok) {
  throw new Error(await response.text());
}

const audioBuffer = await response.arrayBuffer();

// Node.js: save file
import fs from "fs";
fs.writeFileSync("output.wav", Buffer.from(audioBuffer));

console.log("Saved output.wav");
