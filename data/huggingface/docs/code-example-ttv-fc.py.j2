import os
import time
import requests
from pathlib import Path

UNITYSVC_API_KEY = os.getenv("UNITYSVC_API_KEY")
SERVICE_BASE_URL = os.environ.get("SERVICE_BASE_URL")

def text_to_video(
    model_id: str,
    prompt: str,
    output_path: str = "output.mp4",
    retries: int = 5
):
    url = f"{SERVICE_BASE_URL}/models/{{offering.name}}"

    headers = {
        "Authorization": f"Bearer {UNITYSVC_API_KEY}"
    }

    payload = {
        "inputs": prompt
    }

    for attempt in range(retries):
        response = requests.post(url, headers=headers, json=payload)

        if response.status_code == 503:
            time.sleep(3)
            continue

        response.raise_for_status()
        Path(output_path).write_bytes(response.content)
        return output_path

    raise RuntimeError("Model did not become ready in time.")


# ===== Example usage =====
if __name__ == "__main__":
    path = text_to_video(
        model_id="{{offering.name}}",
        prompt="A cinematic shot of a futuristic city at sunset, flying drones"
    )
    print(f"Video saved to {path}")
