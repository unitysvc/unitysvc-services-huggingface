import os
import requests

UNITYSVC_API_KEY = os.getenv("UNITYSVC_API_KEY")
SERVICE_BASE_URL = os.environ.get("SERVICE_BASE_URL")

url = f"{SERVICE_BASE_URL}/models/{{offering.name}}"

headers = {
    "Authorization": f"Bearer {UNITYSVC_API_KEY}",
    "Content-Type": "application/json"
}

payload = {
    "inputs": {
        "source_sentence": "I love machine learning",
        "sentences": [
            "I enjoy studying AI",
            "The weather is nice today",
            "Deep learning is fascinating"
        ]
    }
}

response = requests.post(url, headers=headers, json=payload)
response.raise_for_status()

print(response.json())
