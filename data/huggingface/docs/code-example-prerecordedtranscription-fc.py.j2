import os
import time
import requests

UNITYSVC_API_KEY = os.getenv("UNITYSVC_API_KEY")
SERVICE_BASE_URL = os.environ.get("SERVICE_BASE_URL")

def transcribe_audio(
    model_id: str,
    audio_path: str,
    retries: int = 5
):
    url = f"https://router.huggingface.co/models/{{offering.name}}"

    headers = {
        "Authorization": f"Bearer {UNITYSVC_API_KEY}"
    }

    for _ in range(retries):
        with open(audio_path, "rb") as audio:
            response = requests.post(
                url,
                headers=headers,
                files={"file": audio}
            )

        if response.status_code == 503:
            time.sleep(2)
            continue

        response.raise_for_status()
        return response.json()["text"]

    raise RuntimeError("ASR model not ready.")


# ===== Example usage =====
if __name__ == "__main__":
    text = transcribe_audio(
        model_id="{{offering.name}}",
        audio_path="audio.wav"
    )
    print(text)
