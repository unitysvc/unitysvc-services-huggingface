import fs from "fs";
import FormData from "form-data";

const UNITYSVC_API_KEY = process.env.UNITYSVC_API_KEY;
const SERVICE_BASE_URL = process.env.SERVICE_BASE_URL;

const form = new FormData();
form.append("file", fs.createReadStream("audio.wav"));

const response = await fetch(
  `${SERVICE_BASE_URL}/models/{{offering.name}}`,
  {
    method: "POST",
    headers: {
      "Authorization": `Bearer ${UNITYSVC_API_KEY}`
    },
    body: form
  }
);

if (!response.ok) {
  throw new Error(await response.text());
}

const result = await response.json();
console.log(result.text);
