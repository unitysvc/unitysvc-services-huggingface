{%- set name = (offering_name ~ provider_name) | lower -%}

{%- set example_suffix = "" -%}

{%- if "guard" in name -%}
  {%- set example_suffix = "-guard" -%}

{%- elif "imagetoimage" in name or "image-edit" in name or "outpaint" in name -%}
  {%- set example_suffix = "-imagetoimage" -%}

{%- elif "image" in name or "flux" in name or "diffusion" in name -%}
  {%- set example_suffix = "-image" -%}

{%- elif "ocr" in name or "transcription" in name or "whisper" in name -%}
  {%- set example_suffix = "-prerecordedtranscription" -%}

{%- elif "sentence" in name or "embedding" in name or "bge" in name or "minilm" in name -%}
  {%- set example_suffix = "-sentencetransformers" -%}

{%- elif "tts" in name or "kokoro" in name -%}
  {%- set example_suffix = "-tts" -%}

{%- elif "video" in name or "ltx" in name -%}
  {%- set example_suffix = "-ttv" -%}

{%- endif -%}

{
  "schema": "listing_v1",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
{%- if list_price %}
  "list_price": {{ list_price | tojson }},
{%- endif %}

  "user_access_interfaces": {
    "Provider API": {
      "access_method": "http",
      "base_url": "${GATEWAY_BASE_URL}/p/{{ provider_name }}",
      "routing_key": {
        "model": "{{ offering_name }}"
      }
    }
  },

  "documents": {

    "How to use this model": {
      "category": "getting_started",
      "file_path": "../../docs/description.md",
      "is_active": true,
      "is_public": true,
      "mime_type": "markdown"
    },

    "Python code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/code-example{{ example_suffix }}.py.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "python"
    },

    "Python function calling code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/code-example{{ example_suffix }}-fc.py.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "python"
    },

    "JavaScript code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/code-example{{ example_suffix }}.js.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "javascript"
    },

    "cURL code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/code-example{{ example_suffix }}.sh.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "bash"
    },

    "Connectivity test": {
      "category": "connectivity_test",
      "description": "Connectivity test",
      "file_path": "../../docs/connectivity.sh.j2",
      "is_active": true,
      "is_public": false,
      "mime_type": "bash"
    }

  }
}